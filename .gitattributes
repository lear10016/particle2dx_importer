/.gitignore export-ignore
/.godot export-ignore
/icon.svg export-ignore
/icon.svg.import export-ignore
/main.tscn export-ignore
/particle export-ignore
/plist export-ignore
/project.godot export-ignore
/RELEASE_CHECKLIST.md export-ignore
/STORE_LISTING.md export-ignore
